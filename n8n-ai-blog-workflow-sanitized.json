        "jsonBody": "={\n  \"model\": \"meta-llama/llama-3.1-8b-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a strict JSON generator. You must ONLY return valid JSON. No explanations, no text outside JSON.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a professional blog writer and SEO writer.\\n\\nWrite a blog article based on this title and keyword.\\n\\nTitle: {{$json[\"title\"]}}\\nKeyword: {{$json[\"keyword\"]}}\\n\\nThe structure must follow this style:\\n- a catchy numbered title\\n- a short intro that explains the problem and promises useful ideas\\n- exactly 8 short idea sections\\n- each idea section must have a clear heading and a short practical paragraph\\n- some idea sections can include short bullet points\\n- a short conclusion at the end\\n- include exactly 3 image prompts that fit naturally with the article\\n- do not include markdown fences\\n- return ONLY valid JSON\\n- if the JSON format is not respected, the system will fail\\n\\nReturn exactly in this structure:\\n\\n{\\n  \\\"final_title\\\": \\\"Final title here\\\",\\n  \\\"excerpt\\\": \\\"Short summary here\\\",\\n  \\\"intro\\\": \\\"Intro paragraph here\\\",\\n  \\\"ideas\\\": [\\n    {\\n      \\\"heading\\\": \\\"Idea heading 1\\\",\\n      \\\"content\\\": \\\"Short practical paragraph here\\\",\\n      \\\"bullets\\\": [\\\"Point 1\\\", \\\"Point 2\\\"]\\n    },\\n    {\\n      \\\"heading\\\": \\\"Idea heading 2\\\",\\n      \\\"content\\\": \\\"Short practical paragraph here\\\",\\n      \\\"bullets\\\": []\\n    },\\n    {\\n      \\\"heading\\\": \\\"Idea heading 3\\\",\\n      \\\"content\\\": \\\"Short practical paragraph here\\\",\\n      \\\"bullets\\\": [\\\"Point 1\\\", \\\"Point 2\\\"]\\n    },\\n    {\\n      \\\"heading\\\": \\\"Idea heading 4\\\",\\n      \\\"content\\\": \\\"Short practical paragraph here\\\",\\n      \\\"bullets\\\": []\\n    },\\n    {\\n      \\\"heading\\\": \\\"Idea heading 5\\\",\\n      \\\"content\\\": \\\"Short practical paragraph here\\\",\\n      \\\"bullets\\\": [\\\"Point 1\\\", \\\"Point 2\\\"]\\n    },\\n    {\\n      \\\"heading\\\": \\\"Idea heading 6\\\",\\n      \\\"content\\\": \\\"Short practical paragraph here\\\",\\n      \\\"bullets\\\": []\\n    },\\n    {\\n      \\\"heading\\\": \\\"Idea heading 7\\\",\\n      \\\"content\\\": \\\"Short practical paragraph here\\\",\\n      \\\"bullets\\\": [\\\"Point 1\\\", \\\"Point 2\\\"]\\n    },\\n    {\\n      \\\"heading\\\": \\\"Idea heading 8\\\",\\n      \\\"content\\\": \\\"Short practical paragraph here\\\",\\n      \\\"bullets\\\": []\\n    }\\n  ],\\n  \\\"conclusion\\\": \\\"Short conclusion here\\\",\\n  \\\"image_prompts\\\": [\\n    \\\"Image prompt 1\\\",\\n    \\\"Image prompt 2\\\",\\n    \\\"Image prompt 3\\\"\\n  ]\\n}\"\n    }\n  ],\n  \"temperature\": 0.5\n}",
        "options": {}
