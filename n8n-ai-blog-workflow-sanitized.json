    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const title = item.json.final_title || \"\";\n  const intro = item.json.intro || \"\";\n  const ideas = Array.isArray(item.json.ideas) ? item.json.ideas : [];\n  const conclusion = item.json.conclusion || \"\";\n\n  let html = `<h1>${title}</h1>`;\n  html += `<p>${intro}</p>`;\n\n  ideas.forEach((idea, index) => {\n    html += `<h2>${idea.heading || \"\"}</h2>`;\n    html += `<p>${idea.content || \"\"}</p>`;\n\n    if (Array.isArray(idea.bullets) && idea.bullets.length > 0) {\n      html += \"<ul>\";\n      idea.bullets.forEach(bullet => {\n        html += `<li>${bullet}</li>`;\n      });\n      html += \"</ul>\";\n    }\n\n    if (index === 1) {\n      html += `<p><em>Image placeholder 1</em></p>`;\n    }\n\n    if (index === 4) {\n      html += `<p><em>Image placeholder 2</em></p>`;\n    }\n  });\n\n  html += `<p><em>Image placeholder 3</em></p>`;\n  html += `<p>${conclusion}</p>`;\n\n  return {\n    json: {\n      ...item.json,\n      final_html: html\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
