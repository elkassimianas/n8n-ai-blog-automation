        "jsCode": "return items.map((item, index) => {\n  const raw = item.json.choices[0].message.content;\n  const parsed = JSON.parse(raw);\n\n  const prevRow = $(\"Update row in sheet\").itemMatching(index).json;\n\n  return {\n    json: {\n      row_number: prevRow.row_number,\n      keyword_id: prevRow.keyword_id,\n      keyword: prevRow.keyword,\n      original_title: prevRow.title,\n      sheet_status: prevRow.status,\n      wp_link: prevRow.wp_link || \"\",\n      notes: prevRow.notes || \"\",\n\n      final_title: parsed.final_title || prevRow.title,\n      excerpt: parsed.excerpt || \"\",\n      intro: parsed.intro || \"\",\n      ideas: Array.isArray(parsed.ideas) ? parsed.ideas : [],\n      conclusion: parsed.conclusion || \"\",\n      image_prompts: Array.isArray(parsed.image_prompts) ? parsed.image_prompts : [],\n      article_status: \"article_generated\"\n    }\n  };\n});"
      },
